<div style="background:linear-gradient(135deg,#1D293D,#2D3F5A); border-radius:12px 12px 0 0; padding:0.85rem 1.4rem 0.85rem 1.6rem; position:relative; overflow:hidden;">

    <div style="position:absolute; top:-15px; right:15%; width:70px; height:70px; border-radius:50%; background:rgba(255,255,255,0.04); z-index:0;"></div>
    <div style="position:absolute; bottom:-30px; right:-10px; width:100px; height:100px; border-radius:50%; background:rgba(255,255,255,0.04); z-index:0;"></div>

    <div style="position:relative; z-index:1; display:flex; align-items:center; gap:10px;">
        <div style="width:28px; height:28px; border-radius:7px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fas fa-th-list" style="color:white; font-size:0.75rem;"></i>
        </div>
        <span style="color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9rem;">Applications</span>
        <span style="background:rgba(255,255,255,0.15); color:rgba(255,255,255,0.9); border-radius:10px; padding:1px 9px; font-size:0.72rem; font-weight:600; margin-left:2px;">{{ tower.reports|length }}</span>
    </div>
    
</div>
